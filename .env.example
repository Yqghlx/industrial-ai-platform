# Environment variables template
# Copy to .env and fill in your values

# Database
DB_PASSWORD=industrial_password_change_me

# Authentication
JWT_SECRET=your-jwt-secret-key-change-me-in-production
ADMIN_PASSWORD=your-admin-password-change-me

# Grafana (if using monitoring profile)
GRAFANA_PASSWORD=admin

# API Configuration (optional)
API_URL=http://localhost:8080
FRONTEND_URL=http://localhost

# LLM Provider (optional)
GLM_API_KEY=your-glm-api-key
GLM_API_URL=https://open.bigmodel.cn/api/paas/v4