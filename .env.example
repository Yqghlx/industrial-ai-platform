# Industrial AI Platform Environment Variables
# Copy this file to .env and update values for your deployment

# ====================
# Database Configuration
# ====================
POSTGRES_USER=industrial_ai_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
POSTGRES_DB=industrial_ai

# ====================
# Redis Configuration
# ====================
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD_HERE

# ====================
# Backend Configuration
# ====================
# API URL for frontend to connect
API_URL=http://localhost:8080

# Environment (development, staging, production)
ENV=production

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# ====================
# CORS Configuration
# ====================
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ====================
# LLM Configuration
# ====================
LLM_API_KEY=your_llm_api_key_here
LLM_BASE_URL=https://coding.dashscope.aliyuncs.com/v1
LLM_MODEL=glm-5

# ====================
# Security Notes
# ====================
# 1. NEVER commit .env file to version control
# 2. Use strong, unique passwords for production
# 3. Rotate passwords periodically
# 4. In production, consider using secrets management (Docker secrets, Kubernetes secrets, etc.)