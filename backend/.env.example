# Industrial AI Platform - Backend Environment Variables
# Copy this file to .env and fill in your values

# Database Configuration (REQUIRED)
# Replace with your actual database credentials
DATABASE_URL=postgres://your_user:***@localhost:5432/industrial_ai?sslmode=disable

# Redis Configuration (Optional - Cache Layer)
# If not set, in-memory cache will be used as fallback
REDIS_URL=redis://localhost:6379/0

# Cache Configuration
# Enable/disable caching (default: true)
CACHE_ENABLED=true
# Cache key prefix (default: iai:)
CACHE_PREFIX=iai:

# JWT Authentication (REQUIRED for production)
# Generate a secure random string for JWT signing
# SEC-MED-03: Use scripts/generate-secrets.sh to generate securely
# SEC-MED-03: JWT_SECRET_ROTATION_INTERVAL - rotation interval in hours (default: 24)
# SEC-MED-03: Enable automatic rotation in production for enhanced security
JWT_SECRET=your-secret-key-here
JWT_SECRET_ROTATION_ENABLED=true
JWT_SECRET_ROTATION_INTERVAL=24

# Admin Password Configuration (Optional)
# If not set, a random password will be generated on first startup
# and logged to console. Save this password securely!
# SEC-MED-06: Use scripts/generate-secrets.sh --admin to generate
ADMIN_PASSWORD=your-admin-password-here

# Device API Key (Optional - for device authentication)
# SEC-MED-02: For production telemetry endpoint authentication
# Use scripts/generate-secrets.sh --api-key to generate
DEVICE_API_KEY=

# LLM Configuration (Bailian GLM-5)
LLM_API_KEY=your-llm-api-key
LLM_BASE_URL=https://coding.dashscope.aliyuncs.com/v1
LLM_MODEL=glm-5

# Server Configuration
PORT=8080

# CORS Origins (comma-separated)
# SEC-HIGH-01: 生产环境必须显式设置，不允许使用通配符 "*"
# 示例: CORS_ORIGINS=https://your-domain.com,https://admin.your-domain.com
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# WebSocket Compression Configuration (Optional)
# Enable WebSocket message compression for bandwidth optimization
WS_COMPRESSION_ENABLED=true
# Compression level (1-9): 1=fastest, 9=best compression (default: 6)
WS_COMPRESSION_LEVEL=6
# Minimum message size in bytes to trigger compression (default: 1024)
# Can also use KB/MB format: 1KB, 2KB, 1MB
WS_COMPRESSION_MIN_SIZE=1024

# WebSocket Authentication (Optional)
# SEC-MED-01: Enable JWT authentication for WebSocket connections
WS_AUTH_ENABLED=false
WS_AUTH_TOKEN_PARAM=token

# Telemetry Endpoint Security
# SEC-MED-02: Enable device authentication for telemetry endpoint
TELEMETRY_AUTH_ENABLED=false
TELEMETRY_RATE_LIMIT=1000